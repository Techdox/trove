# Trove Docker agent — static binary on distroless.
# Runs as root so it can read the bind-mounted /var/run/docker.sock (root-owned
# on most hosts). The agent only ever issues read-only GETs to the daemon.
# Dev/compose image; the release counterpart is
# build/docker/Dockerfile.agent-docker — keep base image/user in sync.
FROM golang:1.26 AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags "-s -w" \
    -o /out/trove-agent-docker ./cmd/trove-agent-docker

FROM gcr.io/distroless/static-debian12
COPY --from=build /out/trove-agent-docker /usr/local/bin/trove-agent-docker
ENTRYPOINT ["/usr/local/bin/trove-agent-docker"]

# Release image for trove-agent-proxmox. Talks only to the Proxmox API over
# HTTPS with a read-only token; runs as nonroot.
# Dev/compose counterpart is ../../Dockerfile.agents (CMD=trove-agent-proxmox) —
# keep base image/user in sync.
FROM gcr.io/distroless/static-debian12:nonroot
ARG TARGETPLATFORM
COPY ${TARGETPLATFORM}/trove-agent-proxmox /usr/local/bin/trove-agent-proxmox
ENTRYPOINT ["/usr/local/bin/trove-agent-proxmox"]
